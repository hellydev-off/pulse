{% extends 'layouts/base.twig' %}
{% block bodyClass %}page-profile{% endblock %}
{% block title %}Заказ от 4 апреля 2026 — {{ siteName }}{% endblock %}

{% block content %}
<div class="container">
  <nav class="breadcrumb-nav">
    <a href="/">Главная</a><span class="breadcrumb-nav__sep">—</span>
    <a href="#">Александр</a><span class="breadcrumb-nav__sep">—</span>
    <span>Заказ от 4 апреля 2026</span>
  </nav>

  <div class="profile-layout">
    {% include 'components/profile-sidebar.twig' with { active: 'orders' } %}

    <div class="profile-content">
      <div class="order-detail">

        {# ── Left column: main card + action buttons ── #}
        <div class="order-detail__left">

          {# Main card #}
          <div class="order-detail__main">
            <a href="profile-orders.html" class="order-detail__back">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              К списку заказов
            </a>
            <h1 class="order-detail__title">Заказ от 4 апреля 2026, 16:06</h1>

            <div class="order-detail__status-row">
              <span class="order-detail__status">Собираем
                <svg width="7" height="12" viewBox="0 0 7 12" fill="none"><path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="order-detail__delivery-info">Доставка Деловыми Линиями, курьером, 1000 Р</span>
            </div>

            <div class="order-items-list order-items-list--detail">
              <div class="order-item">
                <img src="/images/catalog/карт1.png" alt="" class="order-item__img">
                <div class="order-item__info">
                  <a href="#" class="order-item__name">Ножи для метания СМН+ (Кизляр)</a>
                  <span class="order-item__article">Артикул: H8A7C9</span>
                </div>
                <span class="order-item__qty">1 шт.</span>
                <div class="order-item__price">
                  <span class="order-item__price-current">6 000 Р</span>
                  <span class="order-item__price-old">7 500 Р</span>
                </div>
              </div>
              <div class="order-item">
                <img src="/images/catalog/карт1.png" alt="" class="order-item__img">
                <div class="order-item__info">
                  <a href="#" class="order-item__name">Ножи для метания СМН+ (Кизляр)</a>
                  <span class="order-item__article">Артикул: H8A7C9</span>
                </div>
                <span class="order-item__qty">2 шт.</span>
                <div class="order-item__price">
                  <span class="order-item__price-dark">14 000 Р</span>
                </div>
              </div>
            </div>
          </div>

          {# Action buttons — отдельные карточки вне основного блока #}
          <div class="order-detail__actions">
            <button type="button" class="order-detail__action-card">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16v.01" stroke-linecap="round"/></svg>
              Вопросы по заказу
            </button>
            <button type="button" class="order-detail__action-card">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/><polyline points="9 12 11 14 15 10"/></svg>
              Чеки по заказу
            </button>
          </div>

        </div>

        {# ── Sidebar ── #}
        <aside class="order-detail__sidebar">
          <div class="order-detail__sidebar-field">
            <p class="order-detail__sidebar-key">Код заказа:</p>
            <p class="order-detail__sidebar-val">0221225037-0010</p>
          </div>
          <div class="order-detail__sidebar-field">
            <p class="order-detail__sidebar-key">Ожидаемая дата доставки:</p>
            <p class="order-detail__sidebar-val order-detail__sidebar-val--bold">11 апреля 2026</p>
          </div>
          <div class="order-detail__sidebar-divider"></div>
          <div class="order-detail__sidebar-row">
            <span>Товары, 3 шт.</span><span>21 500 Р</span>
          </div>
          <div class="order-detail__sidebar-row order-detail__sidebar-row--discount">
            <span>Скидка
              <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="#B1BFCC" stroke-width="1.5"/><path d="M10 9v6M10 7v.01" stroke="#B1BFCC" stroke-width="1.5" stroke-linecap="round"/></svg>
            </span>
            <span>- 1 500 Р</span>
          </div>
          <div class="order-detail__sidebar-row">
            <span>Доставка</span><span>1 000 Р</span>
          </div>
          <div class="order-detail__sidebar-divider"></div>
          <div class="order-detail__sidebar-total">
            <span>Итого</span><span>21 000 Р</span>
          </div>
          <button type="button" class="order-detail__reorder-btn">Повторить заказ</button>
          <label class="order-detail__agree cart-checkbox">
            <input type="checkbox" checked>
            <span class="cart-checkbox__mark"></span>
            <span>Соглашаюсь с <a href="#">правилами пользования</a> и возврата</span>
          </label>
          <button type="button" class="order-detail__cancel-btn">Отменить заказ</button>
        </aside>

      </div>
    </div>
  </div>
</div>
{% endblock %}
