{% extends 'layouts/base.twig' %}
{% block title %}Мои заказы — {{ siteName }}{% endblock %}

{% block content %}
<div class="container">
  <nav class="breadcrumb-nav">
    <a href="/">Главная</a><span class="breadcrumb-nav__sep">—</span>
    <a href="#">Александр</a><span class="breadcrumb-nav__sep">—</span>
    <span>Мои заказы</span>
  </nav>

  <div class="profile-layout">
    {% include 'components/profile-sidebar.twig' with { active: 'orders' } %}

    <div class="profile-content">
      <div class="profile-orders__tabs">
        <button class="profile-orders__tab profile-orders__tab--active" data-otab="active">Заказы</button>
        <button class="profile-orders__tab" data-otab="history">История</button>
        <button class="profile-orders__tab" data-otab="returns">Возвраты</button>
      </div>

      <div class="profile-orders__pane profile-pane--active" id="otab-active">

        {# ── User-created orders (rendered by shop.js, newest first) ── #}
        <div id="userOrders"></div>

        {# ── Order 1: Собираем ── #}
        <div class="order-group">
          <div class="order-group__header">
            <a href="profile-order-detail.html" class="order-group__status">
              Собираем
              <svg width="7" height="12" viewBox="0 0 7 12" fill="none"><path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <div class="order-group__meta-grid">
              <div class="order-group__meta-col">
                <span class="order-group__meta-delivery">Доставка СДЭК, курьером, 1000 Р</span>
                <span class="order-group__expected">Ожидаем 11 апреля 2026, суббота</span>
              </div>
              <div class="order-group__meta-col">
                <span class="order-group__meta-label">Дата заказа:</span>
                <span class="order-group__meta-val">4 апреля 2026, 16:06</span>
              </div>
              <div class="order-group__meta-col">
                <span class="order-group__meta-label">Код заказа:</span>
                <span class="order-group__meta-val">0221225037-0010</span>
              </div>
            </div>
          </div>
          <div class="order-items-list">
            <div class="order-item">
              <img src="/images/catalog/карт1.png" alt="" class="order-item__img">
              <div class="order-item__info">
                <a href="#" class="order-item__name">Ножи для метания СМН+ (Кизляр)</a>
                <span class="order-item__article">Артикул: H8A7C9</span>
              </div>
              <span class="order-item__qty">1 шт.</span>
              <div class="order-item__price">
                <span class="order-item__price-current">6 000 Р</span>
                <span class="order-item__price-old">7 500 Р</span>
              </div>
            </div>
            <div class="order-item">
              <img src="/images/catalog/карт1.png" alt="" class="order-item__img">
              <div class="order-item__info">
                <a href="#" class="order-item__name">Ножи для метания СМН+ (Кизляр)</a>
                <span class="order-item__article">Артикул: H8A7C9</span>
              </div>
              <span class="order-item__qty">2 шт.</span>
              <div class="order-item__price">
                <span class="order-item__price-dark">14 000 Р</span>
              </div>
            </div>
          </div>
        </div>

        {# ── Order 2: В пути ── #}
        <div class="order-group">
          <div class="order-group__header">
            <a href="profile-order-detail.html" class="order-group__status">
              В пути
              <svg width="7" height="12" viewBox="0 0 7 12" fill="none"><path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <div class="order-group__meta-grid">
              <div class="order-group__meta-col">
                <span class="order-group__meta-delivery">Доставка СДЭК, курьером, 1000 Р</span>
                <span class="order-group__expected">Ожидаем 11 апреля 2026, суббота</span>
              </div>
              <div class="order-group__meta-col">
                <span class="order-group__meta-label">Дата заказа:</span>
                <span class="order-group__meta-val">4 апреля 2026, 16:06</span>
              </div>
              <div class="order-group__meta-col">
                <span class="order-group__meta-label">Код заказа:</span>
                <span class="order-group__meta-val">0221225037-0010</span>
              </div>
            </div>
          </div>
          <div class="order-items-list">
            <div class="order-item">
              <img src="/images/catalog/карт1.png" alt="" class="order-item__img">
              <div class="order-item__info">
                <a href="#" class="order-item__name">Ножи для метания СМН+ (Кизляр)</a>
                <span class="order-item__article">Артикул: H8A7C9</span>
              </div>
              <span class="order-item__qty">1 шт.</span>
              <div class="order-item__price">
                <span class="order-item__price-current">6 000 Р</span>
                <span class="order-item__price-old">7 500 Р</span>
              </div>
            </div>
            <div class="order-item">
              <img src="/images/catalog/карт1.png" alt="" class="order-item__img">
              <div class="order-item__info">
                <a href="#" class="order-item__name">Ножи для метания СМН+ (Кизляр)</a>
                <span class="order-item__article">Артикул: H8A7C9</span>
              </div>
              <span class="order-item__qty">2 шт.</span>
              <div class="order-item__price">
                <span class="order-item__price-dark">14 000 Р</span>
              </div>
            </div>
          </div>
        </div>

        {# ── Order 3: Ожидает ── #}
        <div class="order-group">
          <div class="order-group__header">
            <a href="profile-order-detail.html" class="order-group__status order-group__status--accent">
              Ожидает
              <svg width="7" height="12" viewBox="0 0 7 12" fill="none"><path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <div class="order-group__meta-grid">
              <div class="order-group__meta-col">
                <span class="order-group__meta-delivery">Доставка СДЭК, ПВЗ, 500 Р</span>
                <span class="order-group__expected">Ожидаем 11 апреля 2026, суббота</span>
              </div>
              <div class="order-group__meta-col">
                <span class="order-group__meta-label">Дата заказа:</span>
                <span class="order-group__meta-val">4 апреля 2026, 16:06</span>
              </div>
              <div class="order-group__meta-col">
                <span class="order-group__meta-label">Код заказа:</span>
                <span class="order-group__meta-val">0221225037-0010</span>
              </div>
            </div>
          </div>
          <div class="order-items-list">
            <div class="order-item">
              <img src="/images/catalog/карт1.png" alt="" class="order-item__img">
              <div class="order-item__info">
                <a href="#" class="order-item__name">Ножи для метания СМН+ (Кизляр)</a>
                <span class="order-item__article">Артикул: H8A7C9</span>
              </div>
              <span class="order-item__qty">1 шт.</span>
              <div class="order-item__price">
                <span class="order-item__price-current">6 000 Р</span>
                <span class="order-item__price-old">7 500 Р</span>
              </div>
            </div>
            <div class="order-item">
              <img src="/images/catalog/карт1.png" alt="" class="order-item__img">
              <div class="order-item__info">
                <a href="#" class="order-item__name">Ножи для метания СМН+ (Кизляр)</a>
                <span class="order-item__article">Артикул: H8A7C9</span>
              </div>
              <span class="order-item__qty">2 шт.</span>
              <div class="order-item__price">
                <span class="order-item__price-dark">14 000 Р</span>
              </div>
            </div>
          </div>
        </div>

      </div>

      <div class="profile-orders__pane" id="otab-history" hidden>
        <p style="color:#6B7280; padding:20px 0;">История заказов пуста.</p>
      </div>
      <div class="profile-orders__pane" id="otab-returns" hidden>
        <p style="color:#6B7280; padding:20px 0;">Возвратов нет.</p>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
(function($){
  $('.profile-orders__tab').on('click', function(){
    var tab = $(this).data('otab');
    $('.profile-orders__tab').removeClass('profile-orders__tab--active');
    $(this).addClass('profile-orders__tab--active');
    $('.profile-orders__pane').removeClass('profile-pane--active').attr('hidden', true);
    $('#otab-' + tab).addClass('profile-pane--active').removeAttr('hidden');
  });
}(jQuery));
</script>
{% endblock %}
