          <a href="profile.html?tab=notif-settings" class="profile-notif__action-btn">Настройки
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M6.293 4.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L9.586 9 6.293 5.707a1 1 0 010-1.414z"/></svg>
