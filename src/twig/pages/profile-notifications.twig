      </div>{# /notifList #}

      {# ─── Controls ─── #}
      <div class="profile-load-more">
        <button type="button" class="profile-load-more__btn" id="notifLoadMore">Загрузить еще</button>
        <nav class="notif-pagination" id="notifPagination" aria-label="Страницы"></nav>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
(function ($) {
  'use strict';

  var PER_PAGE   = 5;
  var $list      = $('#notifList');
  var $pagination = $('#notifPagination');
  var $loadMore  = $('#notifLoadMore');
  var $items     = $list.children('.notif-item');
  var total      = $items.length;
  var pages      = Math.ceil(total / PER_PAGE);
  var current    = 1;
  var cumulative = false; // true while in load-more (append) mode

  /* ── SVG arrows ── */
  var SVG_PREV = '<svg width="7" height="12" viewBox="0 0 8 14" fill="none"><path d="M7 1L1 7l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  var SVG_NEXT = '<svg width="7" height="12" viewBox="0 0 8 14" fill="none"><path d="M1 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

  /* ── Visible page numbers ── */
  function pageNums(active, last) {
    if (last <= 7) return Array.from({ length: last }, function (_, i) { return i + 1; });
    if (active <= 4)        return [1, 2, 3, 4, 5, '…', last];
    if (active >= last - 3) return [1, '…', last - 4, last - 3, last - 2, last - 1, last];
    return [1, '…', active - 1, active, active + 1, '…', last];
  }

  /* ── Render items ── */
  function renderItems(page, append) {
    var from = append ? 0 : (page - 1) * PER_PAGE;
    var to   = page * PER_PAGE;
    $items.each(function (i) {
      $(this).toggle(i >= from && i < to);
    });
  }

  /* ── Build pagination ── */
  function buildPagination(active) {
    var nums = pageNums(active, pages);
    var html = '';

    html += '<button class="notif-pagination__item notif-pagination__item--arrow" data-dir="-1" aria-label="Назад">' + SVG_PREV + '</button>';

    nums.forEach(function (p) {
      if (p === '…') {
        html += '<span class="notif-pagination__item notif-pagination__item--dots">…</span>';
      } else {
        html += '<button class="notif-pagination__item' +
          (p === active ? ' notif-pagination__item--active' : '') +
          '" data-pg="' + p + '">' + p + '</button>';
      }
    });

    html += '<button class="notif-pagination__item notif-pagination__item--arrow" data-dir="1" aria-label="Вперёд">' + SVG_NEXT + '</button>';

    $pagination.html(html);

    $pagination.find('[data-pg]').on('click', function () {
      goTo(+$(this).data('pg'), false);
    });

    $pagination.find('[data-dir]').on('click', function () {
      var next = current + (+$(this).data('dir'));
      if (next >= 1 && next <= pages) goTo(next, false);
    });
  }

  /* ── Navigate ── */
  function goTo(page, append) {
    current    = page;
    cumulative = append;
    renderItems(page, append);
    buildPagination(page);
    syncLoadMore();

    if (!append) {
      var top = $list[0].getBoundingClientRect().top + window.pageYOffset - 120;
      window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
    }
  }

  /* ── Load-more button ── */
  function syncLoadMore() {
    $loadMore.toggle(current < pages);
  }

  $loadMore.on('click', function () {
    if (current < pages) goTo(current + 1, false);
  });

  /* ── Edge case: single page ── */
  if (pages <= 1) {
    $loadMore.hide();
    return;
  }

  goTo(1, false);

}(jQuery));
</script>
{% endblock %}
