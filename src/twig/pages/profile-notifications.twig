          </div>
        </div>

        {# 14 — акция #}
        <div class="notif-item">
          <div class="notif-item__icon" style="background-image:url(/images/notifications/Иконка.png)"></div>
          <div class="notif-item__body">
            <p class="notif-item__text">Акция! Скидка 30% на мечи и сабли до 26 апреля</p>
            <p class="notif-item__date">29 марта 2026 в 10:00</p>
          </div>
