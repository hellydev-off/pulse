        {# 11 — доставлен #}
        <div class="notif-item">
          <div class="notif-item__icon" style="background-image:url(/images/notifications/Заливкацветом1.png)"></div>
          <div class="notif-item__body">
            <p class="notif-item__text">Ваш заказ №0221225037-0008 был доставлен</p>
