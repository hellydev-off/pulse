          <div class="notif-item__icon" style="background-image:url(/images/notifications/Заливкацветом3.png)"></div>
          <div class="notif-item__body">
            <p class="notif-item__text">Вернули деньги по заказу</p>
            <button type="button" class="notif-item__go-btn">Перейти</button>
            <p class="notif-item__date">04 апреля 2026 в 11:08</p>
          </div>
        </div>

        {# 5 — счёт на оплату #}
        <div class="notif-item">
          <div class="notif-item__icon" style="background-image:url(/images/notifications/Заливкацветом12.png)"></div>
          <div class="notif-item__body">
            <p class="notif-item__text">Выставлен счет на оплату товара, проверьте почту</p>
            <button type="button" class="notif-item__go-btn">Перейти</button>
            <p class="notif-item__date">04 апреля 2026 в 10:08</p>
          </div>
        </div>

        {# 6 — заказ принят #}
        <div class="notif-item">
          <div class="notif-item__icon" style="background-image:url(/images/notifications/Иконка.png)"></div>
          <div class="notif-item__body">
            <p class="notif-item__text">Ваш заказ №0221225037-0011 принят в обработку</p>
