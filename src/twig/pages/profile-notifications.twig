            <p class="notif-item__date">01 апреля 2026 в 12:10</p>
          </div>
        </div>

        {# 12 — чек #}
        <div class="notif-item">
          <div class="notif-item__icon" style="background-image:url(/images/notifications/Заливкацветом12.png)"></div>
