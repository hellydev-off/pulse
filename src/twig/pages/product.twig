{% extends 'layouts/base.twig' %}

{% block title %}Ножи для метания СМН+ (Саро) — {{ siteName }}{% endblock %}

{% block content %}

<div class="container" id="productPage">
  {# ── Breadcrumb ── #}
  <nav class="breadcrumb-nav" aria-label="breadcrumb">
    <a href="/">Главная</a>
    <span class="breadcrumb-nav__sep">—</span>
    <a href="catalog.html">Спортивные метальные ножи</a>
    <span class="breadcrumb-nav__sep">—</span>
    <span id="pdBreadcrumbName">Ножи для метания СМН+ (Саро)</span>
  </nav>

  {# ── Product layout ── #}
  <div class="product-layout">

    {# ── Gallery ── #}
    <div class="product-gallery">
      <div class="product-gallery__main">
        <button type="button" class="product-gallery__arrow product-gallery__arrow--prev" aria-label="Назад">
        <svg width="20" height="33" viewBox="0 0 20 33" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path fill-rule="evenodd" clip-rule="evenodd" d="M16.276 32.979L19.489 29.723L6.42601 16.489L19.489 3.255L16.276 0L1.52588e-05 16.489L16.276 32.979Z" fill="#C5D5E3" />
</svg>
        </button>
        <img id="pdImg" class="product-gallery__main-img" src="/images/catalog/карт1.png" alt="">
        <button type="button" class="product-gallery__arrow product-gallery__arrow--next" aria-label="Вперёд">
         <svg width="20" height="33" viewBox="0 0 20 33" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path fill-rule="evenodd" clip-rule="evenodd" d="M3.213 32.979L0 29.723L13.063 16.489L0 3.255L3.213 0L19.489 16.489L3.213 32.979Z" fill="#C5D5E3" />
</svg>
        </button>
      </div>
      <div class="product-gallery__thumbs" id="pdThumbs">
        <button type="button" class="product-gallery__thumb product-gallery__thumb--active">
          <img class="product-gallery__thumb-img" src="/images/catalog/карт1.png" alt="">
        </button>
        <button type="button" class="product-gallery__thumb">
          <img class="product-gallery__thumb-img" src="/images/catalog/карт1.png" alt="">
        </button>
        <button type="button" class="product-gallery__thumb">
          <img class="product-gallery__thumb-img" src="/images/catalog/карт1.png" alt="">
        </button>
        <button type="button" class="product-gallery__thumb">
          <img class="product-gallery__thumb-img" src="/images/catalog/карт1.png" alt="">
        </button>
      </div>
    </div>

    {# ── Product info ── #}
    <div class="product-info">
      <h1 class="product-info__title" id="pdName">Ножи для метания СМН+ (Саро)</h1>

      <div class="product-info__meta">
        <span class="product-info__status product-info__status--in" id="pdStatus">В наличии</span>
        <span class="product-info__article" id="pdArticle">Артикул: JUZ9BJ</span>
      </div>

      <div class="product-info__price" id="pdPrice">7 000 Р</div>

      <div class="product-info__actions">
        <div class="product-info__qty">
          <button type="button" class="product-info__qty-btn" id="pdQtyDec">−</button>
          <span class="product-info__qty-val" id="pdQty">1</span>
          <button type="button" class="product-info__qty-btn" id="pdQtyInc">+</button>
        </div>
        <button type="button" class="product-info__add-btn" id="pdAddBtn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/></svg>
          Добавить в корзину
        </button>
      </div>

      <div class="product-info__specs">
        <div class="product-info__specs-head">
          <span class="product-info__specs-title">Краткие характеристики:</span>
          <a href="#tab-chars" class="product-info__specs-more">Подробнее
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M6.293 4.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L9.586 9 6.293 5.707a1 1 0 010-1.414z"/></svg>
          </a>
        </div>
        <table class="product-info__specs-table" id="pdSpecs">
          <tr><td class="product-info__specs-key">Общая длина, см</td><td class="product-info__specs-val">24</td></tr>
          <tr><td class="product-info__specs-key">Длина лезвия, см</td><td class="product-info__specs-val">10.8</td></tr>
          <tr><td class="product-info__specs-key">Толщина лезвия, мм</td><td class="product-info__specs-val">5</td></tr>
          <tr><td class="product-info__specs-key">Твёрдость, HRc</td><td class="product-info__specs-val">45</td></tr>
        </table>
      </div>
    </div>

  </div>{# /product-layout #}

  {# ── Product tabs ── #}
  <div class="product-tabs">
    <button class="product-tabs__item product-tabs__item--active" data-tab="desc">Описание</button>
    <button class="product-tabs__item" data-tab="chars" id="tab-chars">Характеристики</button>
    <button class="product-tabs__item" data-tab="delivery">Доставка и оплата</button>
    <button class="product-tabs__item" data-tab="articles">Статьи</button>
  </div>

  <div class="product-tab-content">
    <div class="product-tab-pane product-tab-pane--active" id="product-pane-desc">
      <p class="product-tab-pane__heading">Краткое описание товара:</p>
      <p id="pdDesc">Ножи для метания СМН+ (Саро) — профессиональный инвентарь для спортсменов. Модель разработана с учётом требований к спортивному метанию. Изготовлена из прочной стали, гарантирующей долговечность использования. Оптимальный баланс обеспечивает точность броска и предсказуемую траекторию. Удобная форма и продуманная геометрия лезвия облегчают освоение техники. Подходит как для тренировок, так и для участия в соревнованиях. Выбирайте надёжное снаряжение — выбирайте СМН+!</p>
    </div>
    <div class="product-tab-pane" id="product-pane-chars" hidden>
      <p>Полные характеристики товара будут здесь.</p>
    </div>
    <div class="product-tab-pane" id="product-pane-delivery" hidden>
      <p>Информация о доставке и оплате.</p>
    </div>
    <div class="product-tab-pane" id="product-pane-articles" hidden>
      <p>Статьи о товаре.</p>
    </div>
  </div>

</div>

{# ── Related products (shared component) ── #}
{% include 'components/product-cards.twig' with { title: 'С этим товаром также покупают:' } %}

<div class="container">
  {# ── Other subcategories ── #}
  <section class="catalog-subcats" style="padding-bottom: 0;">
    <h2 class="catalog-section__title">Другие популярные подкатегории:</h2>
    <div class="catalog-subcats__list">
      <a href="#" class="catalog-subcat-tag">Спортивные ножи для метания</a>
      <a href="#" class="catalog-subcat-tag">Чехлы для спортивных ножей</a>
      <a href="#" class="catalog-subcat-tag">Аксессуары для спортивного метания ножей</a>
      <a href="#" class="catalog-subcat-tag">Оборудование для спортивного метания ножей</a>
      <a href="#" class="catalog-subcat-tag">Боксерские перчатки</a>
      <a href="#" class="catalog-subcat-tag">Мечи и сабли</a>
    </div>
  </section>
</div>

{# ── Bestsellers (shared component) ── #}
{% include 'components/product-cards.twig' with { title: 'Хиты продаж:' } %}

{# ── Promo banners ── #}
<div class="container">
  <section class="promo-section">
    <div class="promo-section__head">
      <h2 class="catalog-section__title" style="margin:0;">Выгодные предложения:</h2>
      <a href="#" class="promo-section__all">Все предложения</a>
    </div>
    <div class="promo-section__grid">

      <div class="promo-card-wrap">
        <div class="promo-card promo-card--blue">
          <div class="promo-card__content">
            <div class="promo-card__discount">-30 <span class="promo-card__percent">%</span></div>
            <div class="promo-card__text">на спортивные<br>метательные ножи</div>
            <div class="promo-card__date-badge">с 1 по 26 апреля 2026</div>
          </div>
        </div>
        <a href="#" class="promo-card__cta" aria-label="Подробнее">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M3.5 14.5L14.5 3.5M14.5 3.5H7M14.5 3.5V11" stroke="#1A2236" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="promo-card-wrap">
        <div class="promo-card promo-card--orange">
          <div class="promo-card__content">
            <div class="promo-card__discount">-15 <span class="promo-card__percent">%</span></div>
            <div class="promo-card__text">на спортивные<br>мечи</div>
            <div class="promo-card__date-badge">с 14 по 18 апреля 2026</div>
          </div>
        </div>
        <a href="#" class="promo-card__cta" aria-label="Подробнее">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M3.5 14.5L14.5 3.5M14.5 3.5H7M14.5 3.5V11" stroke="#1A2236" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

    </div>

    <div class="products-section__dots" style="margin-top: 20px;">
      <span class="products-section__dot products-section__dot--active"></span>
      <span class="products-section__dot"></span>
    </div>
  </section>
</div>

{% endblock %}

{% block scripts %}
<script>
(function ($) {
  // Product tabs
  $('.product-tabs__item').on('click', function () {
    var tab = $(this).data('tab');
    $('.product-tabs__item').removeClass('product-tabs__item--active');
    $(this).addClass('product-tabs__item--active');
    $('.product-tab-pane').removeClass('product-tab-pane--active').attr('hidden', true);
    $('#product-pane-' + tab).addClass('product-tab-pane--active').removeAttr('hidden');
  });
}(jQuery));
</script>
{% endblock %}
