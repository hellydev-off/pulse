{% block scripts %}
<script>
(function ($) {
  'use strict';

  var PER_PAGE = 8;
  var $grid    = $('#subcatGrid');
  var $pag     = $('#subcatPagination');
  var $more    = $('#subcatLoadMore');
  var $items   = $grid.children('.product-card');
  var total    = $items.length;
  var pages    = Math.ceil(total / PER_PAGE);
  var current  = 1;

  var SVG_PREV = '<svg width="7" height="12" viewBox="0 0 7 12" fill="none"><path d="M6 1L1 6l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  var SVG_NEXT = '<svg width="7" height="12" viewBox="0 0 7 12" fill="none"><path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

  function pageNums(active, last) {
    if (last <= 7) return Array.from({ length: last }, function (_, i) { return i + 1; });
    if (active <= 4)        return [1, 2, 3, 4, 5, '…', last];
    if (active >= last - 3) return [1, '…', last - 4, last - 3, last - 2, last - 1, last];
    return [1, '…', active - 1, active, active + 1, '…', last];
  }

  function renderItems(page) {
    var from = (page - 1) * PER_PAGE;
    var to   = page * PER_PAGE;
    $items.each(function (i) {
      $(this).toggle(i >= from && i < to);
    });
  }

  function buildPagination(active) {
    var nums = pageNums(active, pages);
    var html = '';

    html += '<button class="subcat-pagination__item subcat-pagination__item--arrow" data-dir="-1">' + SVG_PREV + '</button>';
    nums.forEach(function (p) {
      if (p === '…') {
        html += '<span class="subcat-pagination__item subcat-pagination__item--dots">…</span>';
      } else {
        html += '<button class="subcat-pagination__item' +
          (p === active ? ' subcat-pagination__item--active' : '') +
          '" data-pg="' + p + '">' + p + '</button>';
      }
    });
    html += '<button class="subcat-pagination__item subcat-pagination__item--arrow" data-dir="1">' + SVG_NEXT + '</button>';

    $pag.html(html);

    $pag.find('[data-pg]').on('click', function () {
      goTo(+$(this).data('pg'));
    });
    $pag.find('[data-dir]').on('click', function () {
      var next = current + (+$(this).data('dir'));
      if (next >= 1 && next <= pages) goTo(next);
    });
  }

  function goTo(page) {
    current = page;
    renderItems(page);
    buildPagination(page);
    $more.toggle(current < pages);
    // scroll to grid top
    var top = $grid[0].getBoundingClientRect().top + window.pageYOffset - 120;
    window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
  }

  // Load more — переход на следующую страницу
  $more.on('click', function () {
    if (current < pages) goTo(current + 1);
  });

  // Init
  if (pages <= 1) { $more.hide(); }
  goTo(1);

  // Фильтр-переключатель «Акция» — добавляет класс на обёртку
  $('#filterSale').on('change', function () {
    $(this).closest('.filter-toggle-wrap').toggleClass('is-checked', this.checked);
  });

}(jQuery));
</script>
{% endblock %}
