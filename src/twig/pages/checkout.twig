{% extends 'layouts/base.twig' %}
{% block title %}Оформление заказа — {{ siteName }}{% endblock %}

{% block content %}
<div class="container" id="checkoutPage">

  <nav class="breadcrumb-nav">
    <a href="/">Главная</a><span class="breadcrumb-nav__sep">—</span>
    <a href="cart.html">Корзина</a>
  </nav>

  <h1 class="checkout-page__title">
    Оформление заказа
    <span class="checkout-page__count" id="checkoutOrderCount">0 товаров</span>
  </h1>

  <div class="checkout-layout">

    {# ═══════════ LEFT: main form ═══════════ #}
    <div class="checkout-main">

      {# ── 1. Плательщик ── #}
      <section class="checkout-section">
        <div class="checkout-section__header">
          <span class="checkout-section__num">1.</span>
          <h2 class="checkout-section__title">Информация о плательщике</h2>
        </div>
        <div class="checkout-section__body">

          {# Payer type switcher #}
          <div class="payer-tabs">
            <button type="button" class="payer-tabs__btn payer-tabs__btn--active" data-payer="phys">Физическое лицо</button>
            <button type="button" class="payer-tabs__btn" data-payer="legal">Юридическое лицо</button>
          </div>

          {# ── Физ. лицо ── #}
          <div class="payer-pane payer-pane--active" id="payer-phys">
            <div class="pf-field-grid checkout-field-grid">
              <div class="pf-field checkout-field">
                <span class="pf-field__label">Имя, Фамилия</span>
                <input type="text" class="pf-field__input" id="coName" placeholder="Иванов Николай">
              </div>
              <div class="pf-field checkout-field">
                <span class="pf-field__label">Телефон</span>
                <input type="tel" class="pf-field__input" placeholder="+7 ___ ___-__-__" id="checkoutPhone">
              </div>
            </div>
            <div class="pf-field-grid checkout-field-grid checkout-field-grid--third">
              <div class="pf-field checkout-field">
                <span class="pf-field__label">E-mail</span>
                <input type="email" class="pf-field__input" id="coEmail" placeholder="example@mail.ru">
              </div>
            </div>
          </div>

          {# ── Юр. лицо ── #}
          <div class="payer-pane" id="payer-legal" hidden>

            <p class="checkout-sub-title">Контактные данные:</p>
            <div class="pf-field-grid checkout-field-grid">
              <div class="pf-field checkout-field">
                <span class="pf-field__label">ФИО</span>
                <input type="text" class="pf-field__input" value="Иванов Николай">
              </div>
              <div class="pf-field checkout-field">
                <span class="pf-field__label">Телефон</span>
                <input type="tel" class="pf-field__input" value="+7 812 777-77-77">
              </div>
            </div>
            <div class="pf-field-grid checkout-field-grid checkout-field-grid--third">
              <div class="pf-field checkout-field">
                <span class="pf-field__label">Email</span>
                <input type="email" class="pf-field__input" value="technoprogress@yandex.ru">
              </div>
            </div>

            <div class="checkout-org-head">
              <p class="checkout-sub-title">Данные организации:</p>
              <button type="button" class="checkout-org-select">ООО «ТехноПрогресс»
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M4.293 6.293a1 1 0 011.414 0L8 8.586l2.293-2.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z"/></svg>
              </button>
            </div>
            <div class="pf-field-grid checkout-field-grid">
              <div class="pf-field checkout-field"><span class="pf-field__label">Название организации</span><input type="text" class="pf-field__input" value="ООО «ТехноПрогресс»"></div>
              <div class="pf-field checkout-field"><span class="pf-field__label">ИНН</span><input type="text" class="pf-field__input" value="7715456789"></div>
              <div class="pf-field checkout-field"><span class="pf-field__label">КПП</span><input type="text" class="pf-field__input" value="771501001"></div>
              <div class="pf-field checkout-field"><span class="pf-field__label">Юридический адрес</span><input type="text" class="pf-field__input" value="119049, г. Москва, ул. Шаболовка ..."></div>
              <div class="pf-field checkout-field"><span class="pf-field__label">Расчётный счёт</span><input type="text" class="pf-field__input" value="40702810500000012345"></div>
              <div class="pf-field checkout-field"><span class="pf-field__label">Банк</span><input type="text" class="pf-field__input" value="ПАО «Банк Инноваций»"></div>
              <div class="pf-field checkout-field"><span class="pf-field__label">Корреспондентский счёт</span><input type="text" class="pf-field__input" value="30101810145250000345"></div>
              <div class="pf-field checkout-field"><span class="pf-field__label">БИК</span><input type="text" class="pf-field__input" value="044525345"></div>
            </div>
          </div>

        </div>
      </section>

      {# ── 2. Способ оплаты ── #}
      <section class="checkout-section">
        <div class="checkout-section__header">
          <span class="checkout-section__num">2.</span>
          <h2 class="checkout-section__title">Способ оплаты</h2>
          <span class="checkout-section__chosen" id="payChosen">Выбрано — СБП</span>
        </div>
        <div class="checkout-section__body">

          {# Физ. лицо payment #}
          <div class="pay-options" id="pay-phys">
            <button type="button" class="pay-card pay-card--active" data-pay-label="СБП">
             <img src="/images/order/СБП.png" alt="">
              
            </button>
            <button type="button" class="pay-card" data-pay-label="МИР">
                <img src="/images/order/Карта.png" alt="">
             
            </button>
            <button type="button" class="pay-card" data-pay-label="GPay">
                 <img src="/images/order/Счет.png" alt="">
            
            </button>
           
          </div>

          {# Юр. лицо payment #}
          <div class="pay-options" id="pay-legal" style="display:none">
            <button type="button" class="pay-card pay-card--active" data-pay-label="Счёт на оплату">
               <img src="/images/order/СБП.png" alt="">
              
            </button>
            <button type="button" class="pay-card" data-pay-label="Банковская карта">
                <img src="/images/order/МИР.png" alt="">
            </button>
            <button type="button" class="pay-card" data-pay-label="СБП">
               <img src="/images/order/Sber Pay.png" alt="">
            </button>
               <button type="button" class="pay-card" data-pay-label="СБП">
               <img src="/images/order/Наличные.png" alt="">
            </button>
          </div>

          <p class="pay-note" id="payNote" style="display:none">Счет на оплату будет автоматически сформирован и отправлен на указанную при оформлении заказа почту.</p>

        </div>
      </section>

      {# ── 3. Способ доставки ── #}
      <section class="checkout-section">
        <div class="checkout-section__header">
          <span class="checkout-section__num">3.</span>
          <h2 class="checkout-section__title">Способ доставки</h2>
          <span class="checkout-section__chosen" id="deliveryChosen">Выбрано — Яндекс Доставка</span>
        </div>
        <div class="checkout-section__body">

          <div class="delivery-options">
            <button type="button" class="delivery-card delivery-card--active" data-delivery-label="Яндекс Доставка">
             <img src="/images/delivery/Яндекс Доставка.png" alt="">
            </button>
            <button type="button" class="delivery-card" data-delivery-label="СДЭК">
             <img src="/images/delivery/Сдэк.png" alt="">
            </button>
            <button type="button" class="delivery-card" data-delivery-label="Почта России">
            <img src="/images/delivery/Почта России.png" alt="">
            </button>
            <button type="button" class="delivery-card" data-delivery-label="Деловые Линии">
           <img src="/images/delivery/Деловые Линии.png" alt="">
            </button>
            <button type="button" class="delivery-card delivery-card--more">
              <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M1 1l6 6-6 6" stroke="#374151" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>

          <div class="delivery-form">
            <div class="delivery-form__row">
              <div class="delivery-form__group">
                <label class="delivery-form__label">Способ получения:</label>
                <div class="checkout-select-wrap">
                  <select class="checkout-select">
                    <option>Курьер</option>
                    <option>Пункт выдачи</option>
                    <option>Постамат</option>
                  </select>
                  <svg class="checkout-select-icon" width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M4.293 6.293a1 1 0 011.414 0L8 8.586l2.293-2.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z"/></svg>
                </div>
              </div>
              <div class="delivery-form__group">
                <label class="delivery-form__label">Сроки доставки:</label>
                <div class="checkout-select-wrap">
                  <select class="checkout-select">
                    <option>Экспресс: 1–2 рабочих дня</option>
                    <option>Стандарт: 3–5 рабочих дней</option>
                    <option>Экономный: 7–14 дней</option>
                  </select>
                  <svg class="checkout-select-icon" width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M4.293 6.293a1 1 0 011.414 0L8 8.586l2.293-2.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z"/></svg>
                </div>
              </div>
            </div>

            <label class="delivery-form__label">Адрес получения</label>
            <div class="checkout-address-wrap">
              <input type="text" class="checkout-address" id="coAddress" placeholder="Город, улица, дом, квартира">
              <button type="button" class="checkout-address-clear" aria-label="Очистить">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#B1BFCC" stroke-width="1.2"/><path d="M5 5l4 4M9 5l-4 4" stroke="#B1BFCC" stroke-width="1.2" stroke-linecap="round"/></svg>
              </button>
            </div>

            <div class="delivery-form__info">
              <div>
                <p class="delivery-form__info-label">Ожидаемая дата доставки:</p>
                <p class="delivery-form__info-val">13 апреля 2026</p>
              </div>
              <div>
                <p class="delivery-form__info-label">Итоговая стоимость доставки:</p>
                <p class="delivery-form__info-val">1000 Р</p>
              </div>
            </div>
          </div>

        </div>
      </section>

      {# ── 4. Ваш заказ ── #}
      <section class="checkout-section">
        <div class="checkout-section__header">
          <span class="checkout-section__num">4.</span>
          <h2 class="checkout-section__title">Ваш заказ</h2>
        </div>
        <div class="checkout-section__body">
          <div class="checkout-order__head">
            <span>Товары</span>
            <span>Кол-во</span>
            <span>Стоимость</span>
          </div>
          <div id="checkoutItems"></div>
        </div>
      </section>

    </div>{# /checkout-main #}

    {# ═══════════ RIGHT: sidebar ═══════════ #}
    <aside class="checkout-sidebar">
      <div class="checkout-sidebar__row">
        <span>Товары</span><span id="coGross">0 Р</span>
      </div>
      <div class="checkout-sidebar__row checkout-sidebar__row--discount">
        <span>Скидка
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="#B1BFCC" stroke-width="1.5"/><path d="M10 9v6M10 7v.01" stroke="#B1BFCC" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
        <span id="coDiscount">- 0 Р</span>
      </div>
      <div class="checkout-sidebar__row">
        <span>Доставка</span><span id="coDelivery">0 Р</span>
      </div>

      <div class="checkout-sidebar__divider"></div>

      <div class="checkout-sidebar__total">
        <span>Итого</span><span id="coTotal">0 Р</span>
      </div>

      <div class="checkout-sidebar__date">
        <p class="checkout-sidebar__date-label">Ожидаемая дата доставки:</p>
        <p class="checkout-sidebar__date-val">13 апреля 2026</p>
      </div>

      <p class="checkout-error" id="checkoutError" style="display:none;"></p>

      <button type="button" class="checkout-sidebar__submit" id="coSubmit">Оформить заказ</button>

      <label class="checkout-sidebar__agree cart-checkbox">
        <input type="checkbox" id="coAgree" checked>
        <span class="cart-checkbox__mark"></span>
        <span>Соглашаюсь с <a href="#">правилами пользования торговой площадкой</a> и возврата</span>
      </label>
    </aside>

  </div>{# /checkout-layout #}
</div>
{% endblock %}

{% block scripts %}
<script>
(function ($) {
  'use strict';

  // ── Phone mask for checkout ──
  function applyCheckoutPhoneMask(el) {
    function format(val) {
      var digits = val.replace(/\D/g, '');
      if (!digits) return '';
      if (digits[0] === '8') digits = '7' + digits.slice(1);
      if (digits[0] !== '7') digits = '7' + digits;
      digits = digits.slice(0, 11);
      var r = '+7';
      if (digits.length > 1) r += ' ' + digits.slice(1, 4);
      if (digits.length > 4) r += ' ' + digits.slice(4, 7);
      if (digits.length > 7) r += '-' + digits.slice(7, 9);
      if (digits.length > 9) r += '-' + digits.slice(9, 11);
      return r;
    }

    $(el)
      .on('focus', function () {
        if (!this.value) {
          this.value = '+7 ';
          // Move cursor to end after the prefix
          var self = this;
          setTimeout(function () {
            try { self.setSelectionRange(3, 3); } catch (e) {}
          }, 0);
        }
      })
      .on('input', function () {
        var pos = this.selectionStart;
        var oldLen = this.value.length;
        var fresh = format(this.value);
        if (fresh === '' && this.value !== '' && this.value !== '+7 ') {
          fresh = '+7 ';
        }
        this.value = fresh;
        // Restore cursor position proportionally
        var diff = fresh.length - oldLen;
        try { this.setSelectionRange(Math.max(3, pos + diff), Math.max(3, pos + diff)); } catch (e) {}
      })
      .on('keydown', function (e) {
        // Don't allow deleting the "+7 " prefix
        if ((e.key === 'Backspace' || e.key === 'Delete') && this.value === '+7 ') {
          e.preventDefault();
          this.value = '';
        }
      })
      .on('blur', function () {
        if (this.value === '+7 ' || this.value === '+7') this.value = '';
      });
  }

  applyCheckoutPhoneMask(document.getElementById('checkoutPhone'));

  // ── Agree checkbox: checked by default ──
  $('#coAgree').prop('checked', true);

  // ── Init: ensure correct payment panel on load ──
  $('#pay-phys').show();
  $('#pay-legal').hide();

  // ── Payer type tabs ──
  $('.payer-tabs__btn').on('click', function () {
    var type = $(this).data('payer');
    $('.payer-tabs__btn').removeClass('payer-tabs__btn--active');
    $(this).addClass('payer-tabs__btn--active');

    $('.payer-pane').hide().removeClass('payer-pane--active');
    $('#payer-' + type).show().addClass('payer-pane--active');

    if (type === 'phys') {
      $('#pay-phys').show();
      $('#pay-legal').hide();
      $('#payNote').hide();
      $('#pay-phys .pay-card').first().trigger('click');
    } else {
      $('#pay-phys').hide();
      $('#pay-legal').show();
      $('#pay-legal .pay-card').first().trigger('click');
    }
  });

  // ── Payment method selection ──
  $(document).on('click', '.pay-card', function () {
    var $group = $(this).closest('.pay-options');
    $group.find('.pay-card').removeClass('pay-card--active');
    $(this).addClass('pay-card--active');

    var label = $(this).data('pay-label');
    $('#payChosen').text('Выбрано — ' + label);

    if (label === 'Счёт на оплату') {
      $('#payNote').show();
    } else {
      $('#payNote').hide();
    }
  });

  // ── Delivery method selection ──
  $(document).on('click', '.delivery-card:not(.delivery-card--more)', function () {
    $('.delivery-card').removeClass('delivery-card--active');
    $(this).addClass('delivery-card--active');
    var label = $(this).data('delivery-label');
    $('#deliveryChosen').text('Выбрано — ' + label);
  });

  // ── Address clear ──
  $('.checkout-address-clear').on('click', function () {
    $('.checkout-address').val('').focus();
  });

}(jQuery));
</script>
{% endblock %}
