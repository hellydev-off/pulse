{% extends 'layouts/base.twig' %}

{% block title %}Корзина — {{ siteName }}{% endblock %}

{% block content %}

<div class="container">

  {# ── Breadcrumb ── #}
  <nav class="breadcrumb-nav" aria-label="breadcrumb">
    <a href="/">Главная</a>
    <span class="breadcrumb-nav__sep">—</span>
    <span>Корзина</span>
  </nav>

  {# ── Page title ── #}
  <h1 class="cart-page__title">
    Корзина
    <span class="cart-page__count" id="cartPageCount">0 товаров</span>
  </h1>

  {# ── Main layout ── #}
  <div class="cart-layout">

    {# ── Left: items ── #}
    <div class="cart-main">

      {# Select-all bar #}
      <div class="cart-controls">
        <label class="cart-checkbox">
          <input type="checkbox" id="cartSelectAll" checked>
          <span class="cart-checkbox__mark"></span>
          <span class="cart-controls__label">Выбрать все</span>
        </label>
        <span class="cart-controls__info">Выбраны все товары</span>
        <button type="button" class="cart-controls__remove" id="cartRemoveSelected">
          <svg width="16" height="18" viewBox="0 0 16 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 4h14M5 4V2h6v2M2 4l1 12a1 1 0 001 1h8a1 1 0 001-1L14 4" stroke="#B1BFCC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Удалить выбранное
        </button>
      </div>

      {# Items rendered by shop.js #}
      <div id="cartItems"></div>

    </div>{# /cart-main #}

    {# ── Right: summary ── #}
    <aside class="cart-summary">
      <div class="cart-summary__row">
        <span class="cart-summary__label" id="cartSummaryCount">Товары, 0 шт.</span>
        <span class="cart-summary__value" id="cartGross">0 Р</span>
      </div>
      <div class="cart-summary__row">
        <span class="cart-summary__label">
          Скидка
          <button type="button" class="cart-summary__info-btn" aria-label="Подробнее о скидке">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="10" cy="10" r="9" stroke="#B1BFCC" stroke-width="1.5"/>
              <path d="M10 9v6M10 7v.01" stroke="#B1BFCC" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </span>
        <span class="cart-summary__value cart-summary__value--discount" id="cartDiscount">- 0 Р</span>
      </div>

      <div class="cart-summary__divider"></div>

      <div class="cart-summary__total-row">
        <span class="cart-summary__total-label">Итого</span>
        <span class="cart-summary__total-value" id="cartTotal">0 Р</span>
      </div>

      <a href="checkout.html" class="cart-summary__checkout-btn">Перейти к оформлению</a>

      <label class="cart-summary__agree">
        <input type="checkbox" checked>
        <span class="cart-checkbox__mark"></span>
        <span class="cart-summary__agree-text">
          Соглашаюсь с <a href="#">правилами пользования торговой площадкой</a> и возврата
        </span>
      </label>

      <p class="cart-summary__delivery-note">
        Доступные способы, время, приблизительную стоимость доставки можно узнать при оформлении заказа
      </p>
    </aside>

  </div>{# /cart-layout #}
</div>{# /container #}

{% include 'components/product-cards.twig' with { title: 'С этими товарами также покупают:' } %}

{% endblock %}
