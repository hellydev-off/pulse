{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {

  // ─── Swiper: Screening banners ──────────────────────────────────────────────
  new Swiper('.vb-screening-slider__swiper', {
    slidesPerView: 1,
    loop: true,
    autoplay: {
      delay: 4000,
      disableOnInteraction: false,
    },
    pagination: {
      el: '.vb-screening-slider__pagination',
      clickable: true,
    },
  });

  // ─── Swiper: Reviews ────────────────────────────────────────────────────────
  new Swiper('.reviews-slider__swiper', {
    slidesPerView: 1,
    spaceBetween: 24,
    autoHeight: true,
    navigation: {
      prevEl: '.reviews-slider__prev',
      nextEl: '.reviews-slider__next',
    },
  });

  // ─── Accordion ──────────────────────────────────────────────────────────────
  document.querySelectorAll('.vb-accordion__toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var body = this.nextElementSibling;
      var isOpen = this.classList.contains('is-open');
      this.classList.toggle('is-open', !isOpen);
      body.classList.toggle('is-open', !isOpen);
    });
  });

});
</script>
{% endblock %}
