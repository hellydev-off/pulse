{% extends 'layouts/base.twig' %}
{% block bodyClass %}page-profile{% endblock %}
{% block title %}Настройки — {{ siteName }}{% endblock %}

{% block content %}
<div class="container">
  <nav class="breadcrumb-nav">
    <a href="/">Главная</a><span class="breadcrumb-nav__sep">—</span>
    <a href="#">Александр</a><span class="breadcrumb-nav__sep">—</span>
    <span>Настройки</span>
  </nav>

  <div class="profile-layout">
    {% include 'components/profile-sidebar.twig' with { active: 'settings' } %}

    <div class="profile-content">

      {# ── Inner tabs ── #}
      <div class="profile-tabs">
        <button class="profile-tabs__item profile-tabs__item--active" data-ptab="profile">Профиль</button>
        <button class="profile-tabs__item" data-ptab="companies">Компании</button>
        <button class="profile-tabs__item" data-ptab="notif-settings">Настройки уведомлений</button>
      </div>

      {# ── Профиль ── #}
      <div class="profile-pane profile-pane--active" id="ptab-profile">
        <p class="profile-section-title">Основные данные</p>
        <div class="pf-field-grid">
          <div class="pf-field">
            <span class="pf-field__label">ФИО</span>
            <input type="text" class="pf-field__input" value="Иванов Николай">
          </div>
          <div class="pf-field">
            <span class="pf-field__label">Телефон</span>
            <input type="tel" class="pf-field__input" value="+7 812 777-77-77">
          </div>
          <div class="pf-field">
            <span class="pf-field__label">Email</span>
            <input type="email" class="pf-field__input" value="technoprogress@yandex.ru">
          </div>
          <div class="pf-field">
            <span class="pf-field__label">Пароль</span>
            <input type="password" class="pf-field__input" placeholder="Назначьте пароль для входа">
          </div>
        </div>
      </div>

      {# ── Компании ── #}
      <div class="profile-pane" id="ptab-companies" hidden>
        <button type="button" class="pf-add-company">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="#374151" stroke-width="1.5"/><path d="M10 6v8M6 10h8" stroke="#374151" stroke-width="1.5" stroke-linecap="round"/></svg>
          Добавить новую компанию
        </button>

        <div class="pf-company">
          <div class="pf-company__header">
            <span class="pf-company__name">ООО «ТехноПрогресс»:</span>
            <a href="#" class="pf-company__delete">Удалить компанию</a>
          </div>
          <div class="pf-field-grid">
            <div class="pf-field"><span class="pf-field__label">Название организации</span><input type="text" class="pf-field__input" value="ООО «ТехноПрогресс»"></div>
            <div class="pf-field"><span class="pf-field__label">ИНН</span><input type="text" class="pf-field__input" value="7715456789"></div>
            <div class="pf-field"><span class="pf-field__label">КПП</span><input type="text" class="pf-field__input" value="771501001"></div>
            <div class="pf-field"><span class="pf-field__label">Юридический адрес</span><input type="text" class="pf-field__input" value="119049, г. Москва, ул. Шаболовка ..."></div>
            <div class="pf-field"><span class="pf-field__label">Расчётный счёт</span><input type="text" class="pf-field__input" value="40702810500000012345"></div>
            <div class="pf-field"><span class="pf-field__label">Банк</span><input type="text" class="pf-field__input" value="ПАО «Банк Инноваций»"></div>
            <div class="pf-field"><span class="pf-field__label">Корреспондентский счёт</span><input type="text" class="pf-field__input" value="30101810145250000345"></div>
            <div class="pf-field"><span class="pf-field__label">БИК</span><input type="text" class="pf-field__input" value="044525345"></div>
          </div>
        </div>

        <div class="pf-company">
          <div class="pf-company__header">
            <span class="pf-company__name">ООО «ТехноЮнион»:</span>
            <a href="#" class="pf-company__delete">Удалить компанию</a>
          </div>
          <div class="pf-field-grid">
            <div class="pf-field"><span class="pf-field__label">Название организации</span><input type="text" class="pf-field__input" value="ООО «Техно Юнионс»"></div>
            <div class="pf-field"><span class="pf-field__label">ИНН</span><input type="text" class="pf-field__input" value="7715456789"></div>
            <div class="pf-field"><span class="pf-field__label">КПП</span><input type="text" class="pf-field__input" value="771501001"></div>
            <div class="pf-field"><span class="pf-field__label">Юридический адрес</span><input type="text" class="pf-field__input" value="119049, г. Москва, ул. Шаболовка ..."></div>
            <div class="pf-field"><span class="pf-field__label">Расчётный счёт</span><input type="text" class="pf-field__input" value="40702810500000012345"></div>
            <div class="pf-field"><span class="pf-field__label">Банк</span><input type="text" class="pf-field__input" value="ПАО «Банк Инноваций»"></div>
            <div class="pf-field"><span class="pf-field__label">Корреспондентский счёт</span><input type="text" class="pf-field__input" value="30101810145250000345"></div>
            <div class="pf-field"><span class="pf-field__label">БИК</span><input type="text" class="pf-field__input" value="044525345"></div>
          </div>
        </div>
      </div>

      {# ── Настройки уведомлений ── #}
      <div class="profile-pane" id="ptab-notif-settings" hidden>

        <div class="pf-notif-group">
          <p class="pf-notif-group__title">Уведомления по заказам на email</p>
          <p class="pf-notif-group__hint">Пуш-уведомления включены по умолчанию</p>
          <div class="pf-toggle-row"><span class="pf-toggle-row__label">Email</span><label class="pf-toggle"><input type="checkbox" checked><span class="pf-toggle__slider"></span></label></div>
        </div>

        <div class="pf-notif-group">
          <p class="pf-notif-group__title">Электронные чеки</p>
          <p class="pf-notif-group__hint">Все ваши чеки хранятся в личном кабинете на странице Электронные чеки</p>
          <div class="pf-toggle-row"><span class="pf-toggle-row__label">Пуш-уведомления</span><label class="pf-toggle"><input type="checkbox" checked><span class="pf-toggle__slider"></span></label></div>
          <div class="pf-toggle-row"><span class="pf-toggle-row__label">Email</span><label class="pf-toggle"><input type="checkbox" checked><span class="pf-toggle__slider"></span></label></div>
          <div class="pf-toggle-row"><span class="pf-toggle-row__label">СМС</span><label class="pf-toggle"><input type="checkbox" checked><span class="pf-toggle__slider"></span></label></div>
        </div>

        <div class="pf-notif-group">
          <p class="pf-notif-group__title">Только для вас</p>
          <p class="pf-notif-group__hint">Персональные рекомендации, скидки и бонусы</p>
          <div class="pf-toggle-row"><span class="pf-toggle-row__label">Пуш-уведомления</span><label class="pf-toggle"><input type="checkbox"><span class="pf-toggle__slider"></span></label></div>
          <div class="pf-toggle-row"><span class="pf-toggle-row__label">Email</span><label class="pf-toggle"><input type="checkbox"><span class="pf-toggle__slider"></span></label></div>
        </div>

        <div class="pf-notif-group">
          <p class="pf-notif-group__title">Скидки и акции</p>
          <p class="pf-notif-group__hint">Экономьте на акциях и распродажах</p>
          <div class="pf-toggle-row"><span class="pf-toggle-row__label">Пуш-уведомления</span><label class="pf-toggle"><input type="checkbox"><span class="pf-toggle__slider"></span></label></div>
          <div class="pf-toggle-row"><span class="pf-toggle-row__label">Email</span><label class="pf-toggle"><input type="checkbox"><span class="pf-toggle__slider"></span></label></div>
          <div class="pf-toggle-row"><span class="pf-toggle-row__label">СМС</span><label class="pf-toggle"><input type="checkbox" checked><span class="pf-toggle__slider"></span></label></div>
        </div>

      </div>

    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
(function($){
  function switchTab(tab) {
    $('.profile-tabs__item').removeClass('profile-tabs__item--active');
    $('[data-ptab="' + tab + '"]').addClass('profile-tabs__item--active');
    $('.profile-pane').removeClass('profile-pane--active').attr('hidden', true);
    $('#ptab-' + tab).addClass('profile-pane--active').removeAttr('hidden');
  }

  $('.profile-tabs__item').on('click', function(){
    switchTab($(this).data('ptab'));
  });

  // Открыть нужную вкладку по параметру ?tab=
  var urlTab = new URLSearchParams(window.location.search).get('tab');
  if (urlTab) switchTab(urlTab);
}(jQuery));
</script>
{% endblock %}
