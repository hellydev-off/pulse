{% extends 'layouts/base.twig' %}

{% block title %}Каталог — {{ siteName }}{% endblock %}

{% block content %}

<div class="container">

  {# ── Breadcrumb ── #}
  <nav class="breadcrumb-nav" aria-label="breadcrumb">
    <a href="/">Главная</a>
    <span class="breadcrumb-nav__sep">—</span>
    <span>Каталог</span>
  </nav>

  {# ── Main categories ── #}
  <section class="catalog-cats">
    <h2 class="catalog-section__title">Основные категории товаров:</h2>
    <div class="catalog-cats__grid">

      <a href="catalog-category.html" class="catalog-cat-card">
        <span class="catalog-cat-card__name">Спортивное<br>метание ножа</span>
        <img src="/images/catalog/Фон.png" alt="Спортивное метание ножа" class="catalog-cat-card__img">
      </a>

      <a href="#" class="catalog-cat-card catalog-cat-card--active">
        <span class="catalog-cat-card__name">Мечевой бой</span>
        <img src="/images/catalog/Фон2.png" alt="Мечевой бой" class="catalog-cat-card__img">
      </a>

      <a href="#" class="catalog-cat-card">
        <span class="catalog-cat-card__name">Бокс</span>
        <img src="/images/catalog/фон3.png" alt="Бокс" class="catalog-cat-card__img">
      </a>

    </div>
  </section>

  {# ── Popular subcategories ── #}
  <section class="catalog-subcats">
    <h2 class="catalog-section__title">Популярные подкатегории:</h2>
    <div class="catalog-subcats__list">
      <a href="#" class="catalog-subcat-tag">Спортивные ножи для метания</a>
      <a href="#" class="catalog-subcat-tag">Чехлы для спортивных ножей</a>
      <a href="#" class="catalog-subcat-tag">Аксессуары для спортивного метания ножей</a>
      <a href="#" class="catalog-subcat-tag">Оборудование для спортивного метания ножей</a>
      <a href="#" class="catalog-subcat-tag">Боксерские перчатки</a>
      <a href="#" class="catalog-subcat-tag">Мечи и сабли</a>
    </div>
  </section>

</div>

{# ── Bestsellers (shared component) ── #}
{% include 'components/product-cards.twig' with { title: 'Хиты продаж:' } %}

{# ── New arrivals (shared component) ── #}
{% include 'components/product-cards.twig' with { title: 'Новинки:' } %}

{% endblock %}
