<div class="auth-overlay" id="loginModal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
  <div class="auth-dialog">

    <button class="auth-dialog__close" id="modalClose" aria-label="Закрыть">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M1 1L17 17M17 1L1 17" stroke="#374151" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <h2 class="auth-dialog__title" id="modalTitle">Вход / Регистрация</h2>

    {# ── Tabs ── #}
    <div class="auth-dialog__tabs" role="tablist">
      <button class="auth-dialog__tab auth-dialog__tab--active" role="tab" aria-selected="true"  data-tab="phone">По телефону</button>
      <button class="auth-dialog__tab"                          role="tab" aria-selected="false" data-tab="email">По e-mail</button>
    </div>

    {# ── Phone pane ── #}
    <div class="auth-pane auth-pane--active" id="modal-pane-phone" role="tabpanel">
      <p class="auth-pane__label">Введите номер телефона</p>
      <p class="auth-pane__hint">Мы отправим код или позвоним. Отвечать на звонок не нужно. Код может прийти в SMS или push</p>

      <div class="auth-pane__field">
        <input type="tel" id="phoneInput" class="auth-pane__input" placeholder="+7 ___ ___-__-__" maxlength="18" autocomplete="tel">
        <span class="auth-pane__error" id="phoneError">Введите корректный номер телефона</span>
      </div>

      <button type="button" class="auth-pane__submit" id="phoneSubmit">Получить код</button>

      <div class="auth-pane__divider"><span>ИЛИ</span></div>

      <button type="button" class="auth-pane__social">
        <span class="auth-pane__social-icons">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <rect width="24" height="24" rx="6" fill="#FC3F1D"/>
            <path d="M13.534 19H15.8V5H12.37C9.11 5 7.4 6.66 7.4 9.18c0 2.14 1.07 3.39 3.01 4.71L7 19h2.42l3.29-5.47-.97-.62C9.98 11.91 9.32 11 9.32 9.08c0-1.67.93-2.7 3.07-2.7h1.14V19z" fill="#fff"/>
          </svg>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <rect width="24" height="24" rx="6" fill="#000"/>
            <circle cx="12" cy="12" r="4" fill="#fff"/>
            <circle cx="12" cy="12" r="2" fill="#000"/>
          </svg>
        </span>
        Войти с Яндекс ID
      </button>

      <button type="button" class="auth-pane__social">
        <span class="auth-pane__social-icons">
          <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
            <rect width="26" height="26" rx="6" fill="#0077FF"/>
            <path d="M18.5 10c.12-.4 0-.7-.57-.7h-1.9c-.48 0-.7.25-.82.53 0 0-.97 2.35-2.34 3.88-.44.44-.64.58-.88.58-.12 0-.3-.14-.3-.54v-4.3c0-.48-.14-.7-.54-.7H8.6c-.3 0-.48.22-.48.43 0 .45.67.55.74 1.82v2.76c0 .6-.11.72-.35.72-.64 0-2.22-2.37-3.16-5.09-.18-.52-.37-.73-.85-.73H2.6c-.54 0-.65.25-.65.53 0 .5.65 2.97 3.02 6.24C6.5 18.5 8.6 19.6 10.5 19.6c1.13 0 1.27-.26 1.27-.7v-1.7c0-.54.11-.65.5-.65.28 0 .77.14 1.89 1.23C15.4 19.1 15.62 19.6 16.3 19.6h1.89c.54 0 .81-.26.65-.78-.17-.51-.79-1.26-1.6-2.15-.44-.53-1.1-1.09-1.3-1.37-.28-.36-.2-.51 0-.83 0 0 2.32-3.28 2.56-4.47z" fill="#fff"/>
          </svg>
        </span>
        Войти с VK ID
      </button>
    </div>

    {# ── Email pane ── #}
    <div class="auth-pane" id="modal-pane-email" role="tabpanel" hidden>
      <p class="auth-pane__label">Введите e-mail</p>
      <p class="auth-pane__hint">Мы отправим ссылку для входа на указанный адрес электронной почты</p>

      <div class="auth-pane__field">
        <input type="email" id="emailInput" class="auth-pane__input" placeholder="example@mail.ru" autocomplete="email">
        <span class="auth-pane__error" id="emailError">Введите корректный e-mail адрес</span>
      </div>

      <button type="button" class="auth-pane__submit" id="emailSubmit">Получить ссылку</button>

      <div class="auth-pane__divider"><span>ИЛИ</span></div>

      <button type="button" class="auth-pane__social">
        <span class="auth-pane__social-icons">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <rect width="24" height="24" rx="6" fill="#FC3F1D"/>
            <path d="M13.534 19H15.8V5H12.37C9.11 5 7.4 6.66 7.4 9.18c0 2.14 1.07 3.39 3.01 4.71L7 19h2.42l3.29-5.47-.97-.62C9.98 11.91 9.32 11 9.32 9.08c0-1.67.93-2.7 3.07-2.7h1.14V19z" fill="#fff"/>
          </svg>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <rect width="24" height="24" rx="6" fill="#000"/>
            <circle cx="12" cy="12" r="4" fill="#fff"/>
            <circle cx="12" cy="12" r="2" fill="#000"/>
          </svg>
        </span>
        Войти с Яндекс ID
      </button>

      <button type="button" class="auth-pane__social">
        <span class="auth-pane__social-icons">
          <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
            <rect width="26" height="26" rx="6" fill="#0077FF"/>
            <path d="M18.5 10c.12-.4 0-.7-.57-.7h-1.9c-.48 0-.7.25-.82.53 0 0-.97 2.35-2.34 3.88-.44.44-.64.58-.88.58-.12 0-.3-.14-.3-.54v-4.3c0-.48-.14-.7-.54-.7H8.6c-.3 0-.48.22-.48.43 0 .45.67.55.74 1.82v2.76c0 .6-.11.72-.35.72-.64 0-2.22-2.37-3.16-5.09-.18-.52-.37-.73-.85-.73H2.6c-.54 0-.65.25-.65.53 0 .5.65 2.97 3.02 6.24C6.5 18.5 8.6 19.6 10.5 19.6c1.13 0 1.27-.26 1.27-.7v-1.7c0-.54.11-.65.5-.65.28 0 .77.14 1.89 1.23C15.4 19.1 15.62 19.6 16.3 19.6h1.89c.54 0 .81-.26.65-.78-.17-.51-.79-1.26-1.6-2.15-.44-.53-1.1-1.09-1.3-1.37-.28-.36-.2-.51 0-.83 0 0 2.32-3.28 2.56-4.47z" fill="#fff"/>
          </svg>
        </span>
        Войти с VK ID
      </button>
    </div>

  </div>
</div>
